<?xml version="1.0" encoding="utf-8"?>
<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <Style src="project://database/Assets/UI/Styles/MainMenuStyles.uss" />

    <ui:VisualElement name="contenedor-principal" class="root">

        <!-- ══ SECCIÓN MENÚ PRINCIPAL ══ -->
        <ui:VisualElement name="seccion-menu" class="menu-section">

            <!-- Título estilo NES -->
            <ui:Label text="BOMBERMAN" class="title" />
            <ui:Label text="► START    CONTINUE" class="title-sub" />
            
            <ui:VisualElement class="title-divider" />

            <!-- Botones principales -->
            <ui:Button name="btn-crear" text="► CREAR SALA" class="btn-main" />
            <ui:Button name="btn-llm"   text="► JUGAR VS IA" class="btn-main" />

            <!-- Fila: código + unirse -->
            <ui:VisualElement class="join-row">
                <ui:TextField name="input-codigo" placeholder-text="CÓDIGO" class="code-input" />
                <ui:Button name="btn-unirse" text="UNIRSE" class="btn-join" />
            </ui:VisualElement>

        </ui:VisualElement>

        <!-- ══ SECCIÓN LOBBY ══ -->
        <ui:VisualElement name="seccion-lobby" style="display: none;" class="lobby-section">

            <ui:Label text="SALA CREADA" class="lobby-title" />
            <ui:Label name="label-codi-sala" text="AB12CD" class="lobby-code" />

            <ui:VisualElement class="lobby-divider" />

            <ui:Label name="label-espectadors" text="1/2 jugadores conectados" class="lobby-players" />
            <ui:Button name="btn-iniciar" text="► INICIAR PARTIDA" class="btn-main" />
            <ui:Button name="btn-tornar-menu" text="◄ VOLVER" class="btn-secondary" />

        </ui:VisualElement>

    </ui:VisualElement>
</ui:UXML>